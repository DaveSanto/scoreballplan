rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isTeamAdmin(teamData) {
      return request.auth != null
          && (request.auth.uid == teamData.ownerId
              || request.auth.uid == teamData.captainId
              || (teamData.coAdminIds != null && request.auth.uid in teamData.coAdminIds));
    }

    function isTeamMember(teamData) {
      return isTeamAdmin(teamData)
          || (request.auth != null
              && teamData.viewerIds != null
              && request.auth.uid in teamData.viewerIds);
    }

    match /teams/{teamId} {
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.ownerId;
      allow read: if isTeamMember(resource.data);
      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.ownerId;
      // Full update for admins; or self-add to coAdminIds (editor invite); or self-add to viewerIds (viewer invite)
      allow update: if isTeamAdmin(resource.data)
                    || (request.auth != null
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['coAdminIds', 'updatedAt'])
                        && request.auth.uid in request.resource.data.get('coAdminIds', []))
                    || (request.auth != null
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewerIds', 'updatedAt'])
                        && request.auth.uid in request.resource.data.get('viewerIds', []));

      match /games/{gameId} {
        allow read: if isTeamMember(
          get(/databases/$(database)/documents/teams/$(teamId)).data
        );
        allow write: if isTeamAdmin(
          get(/databases/$(database)/documents/teams/$(teamId)).data
        );
      }
    }

    match /leagues/{leagueId} {
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.ownerId;
      allow read, update, delete: if request.auth != null
                                  && request.auth.uid == resource.data.ownerId;
      // Captains of teams in this league can read the league (for schedule, invites)
      allow read: if request.auth != null;
    }

    match /players/{playerId} {
      // Anyone signed in can create a player (addedBy = their uid)
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.addedBy;
      // Any signed-in user can read player profiles (needed for team members viewing shared rosters)
      allow read: if request.auth != null;
      // Only the adder or claimer can update
      allow update: if request.auth != null
                    && (request.auth.uid == resource.data.addedBy
                        || request.auth.uid == resource.data.claimedBy);
      // Only the adder can delete
      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.addedBy;
    }

    match /leagueInvites/{inviteId} {
      // League coordinator creates invites
      allow create: if request.auth != null;
      // Anyone can read an invite (needed for token lookup without auth)
      allow read: if true;
      // Only the invited user (via email match) or league owner can update status
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    match /teamInvites/{inviteId} {
      // Any signed-in user can create a team invite (they own the team)
      allow create: if request.auth != null;
      // Anyone can read (needed for token lookup before sign-in)
      allow read: if true;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

  }
}
